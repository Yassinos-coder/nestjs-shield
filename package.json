{
  "name": "nestjs-shield",
  "version": "1.0.0",
  "description": "Layered API protection for NestJS: rate limiting, IP allow/block lists, auto-ban, slow-down, UA filtering, burst caps, payload limits. Pluggable storage (memory/Redis).",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nestjs",
    "rate-limit",
    "rate-limiting",
    "throttle",
    "throttler",
    "shield",
    "security",
    "api-protection",
    "ddos",
    "token-bucket",
    "sliding-window",
    "leaky-bucket",
    "ip-blacklist",
    "ip-whitelist",
    "auto-ban",
    "slow-down",
    "redis"
  ],
  "author": "yassinoscoder",
  "license": "MIT",
  "homepage": "https://github.com/Yassinos-coder/nestjs-shield#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Yassinos-coder/nestjs-shield.git"
  },
  "bugs": {
    "url": "https://github.com/Yassinos-coder/nestjs-shield/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "@nestjs/common": "^9.0.0 || ^10.0.0 || ^11.0.0",
    "@nestjs/core": "^9.0.0 || ^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": {
      "optional": true
    }
  },
  "dependencies": {
    "ipaddr.js": "^2.2.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@types/node": "^20.12.0",
    "ioredis": "^5.4.1",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^5.0.7",
    "rxjs": "^7.8.1",
    "typescript": "^5.4.5"
  }
}
